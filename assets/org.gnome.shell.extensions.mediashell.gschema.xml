<?xml version="1.0" encoding="UTF-8"?>
<schemalist>

  <enum id="org.gnome.shell.extensions.mediashell.input-actions">
    <value nick="NONE"             value="0"  />
    <value nick="PLAY_PAUSE"       value="1"  />
    <value nick="NEXT_TRACK"       value="2"  />
    <value nick="PREVIOUS_TRACK"   value="3"  />
    <value nick="VOLUME_UP"        value="4"  />
    <value nick="VOLUME_DOWN"      value="5"  />
    <value nick="TOGGLE_LOOP"      value="6"  />
    <value nick="TOGGLE_SHUFFLE"   value="7"  />
    <value nick="TOGGLE_POPUP"     value="8"  />
    <value nick="RAISE_APP"        value="9"  />
    <value nick="QUIT_APP"         value="10" />
    <value nick="OPEN_PREFERENCES" value="11" />
    <value nick="NEXT_APP"         value="12" />
  </enum>

  <enum id="org.gnome.shell.extensions.mediashell.panel-positions">
    <value nick="Left"   value="0" />
    <value nick="Center" value="1" />
    <value nick="Right"  value="2" />
  </enum>

  <enum id="org.gnome.shell.extensions.mediashell.visualizer-styles">
    <value nick="WAVE"  value="0" />
    <value nick="PULSE" value="1" />
  </enum>

  <schema id="org.gnome.shell.extensions.mediashell"
          path="/org/gnome/shell/extensions/mediashell/">

    <!-- Popup -->
    <key name="popup-width" type="u">
      <range min="250" max="500" />
      <default>250</default>
    </key>
    <key name="popup-album-art-show" type="b">
      <default>true</default>
    </key>
    <key name="popup-album-art-corner-radius" type="u">
      <range min="0" max="50" />
      <default>20</default>
    </key>
    <key name="popup-track-information-show" type="b">
      <default>true</default>
    </key>
    <key name="popup-track-information-content" type="as">
      <default>['TITLE', 'ARTIST', 'ALBUM']</default>
    </key>
    <key name="popup-progress-bar-show" type="b">
      <default>true</default>
    </key>
    <key name="popup-track-information-scroll-enabled" type="b">
      <default>false</default>
    </key>
    <key name="popup-track-information-scroll-speed" type="u">
      <range min="1" max="10" />
      <default>4</default>
    </key>
    <key name="popup-track-information-scroll-pause-time" type="u">
      <range min="0" max="10" />
      <default>0</default>
    </key>
    <key name="popup-app-icon-use-color" type="b">
      <default>true</default>
    </key>

    <!-- Top bar -->
    <key name="top-bar-track-information-show" type="b">
      <default>true</default>
    </key>
    <key name="top-bar-track-information-width" type="u">
      <range min="0" max="1000" />
      <default>200</default>
    </key>
    <key name="top-bar-track-information-width-lock" type="b">
      <default>false</default>
    </key>
    <key name="top-bar-track-information-scroll-enabled" type="b">
      <default>false</default>
    </key>
    <key name="top-bar-track-information-scroll-speed" type="u">
      <range min="1" max="10" />
      <default>4</default>
    </key>
    <key name="top-bar-track-information-scroll-pause-time" type="u">
      <range min="0" max="10" />
      <default>0</default>
    </key>
    <key name="top-bar-track-information-content" type="as">
      <default>['TITLE', '•', 'ARTIST']</default>
    </key>
    <key name="top-bar-app-icon-show" type="b">
      <default>true</default>
    </key>
    <key name="top-bar-app-icon-use-color" type="b">
      <default>false</default>
    </key>
    <key name="top-bar-visualizer-show" type="b">
      <default>false</default>
    </key>
    <key name="top-bar-visualizer-style"
         enum="org.gnome.shell.extensions.mediashell.visualizer-styles">
      <default>'WAVE'</default>
    </key>
    <key name="top-bar-visualizer-speed" type="u">
      <range min="1" max="8" />
      <default>4</default>
    </key>
    <key name="top-bar-playback-controls-show" type="b">
      <default>true</default>
    </key>
    <key name="top-bar-playback-controls-play-pause-show" type="b">
      <default>true</default>
    </key>
    <key name="top-bar-playback-controls-next-track-show" type="b">
      <default>true</default>
    </key>
    <key name="top-bar-playback-controls-previous-track-show" type="b">
      <default>true</default>
    </key>
    <key name="top-bar-element-order" type="as">
      <default>['APP_ICON', 'TRACK_INFORMATION', 'VISUALIZER', 'PLAYBACK_CONTROLS']</default>
    </key>

    <!-- Panel -->
    <key name="panel-position"
         enum="org.gnome.shell.extensions.mediashell.panel-positions">
      <default>'Center'</default>
    </key>
    <key name="panel-index" type="u">
      <range min="0" max="100" />
      <default>0</default>
    </key>

    <!-- Interactions -->
    <key name="interactions-shortcut-play-pause" type="as">
      <default><![CDATA[['']]]></default>
    </key>
    <key name="interactions-shortcut-next-track" type="as">
      <default><![CDATA[['']]]></default>
    </key>
    <key name="interactions-shortcut-previous-track" type="as">
      <default><![CDATA[['']]]></default>
    </key>
    <key name="interactions-shortcut-volume-up" type="as">
      <default><![CDATA[['']]]></default>
    </key>
    <key name="interactions-shortcut-volume-down" type="as">
      <default><![CDATA[['']]]></default>
    </key>
    <key name="interactions-shortcut-toggle-loop" type="as">
      <default><![CDATA[['']]]></default>
    </key>
    <key name="interactions-shortcut-toggle-shuffle" type="as">
      <default><![CDATA[['']]]></default>
    </key>
    <key name="interactions-shortcut-toggle-popup" type="as">
      <default><![CDATA[['']]]></default>
    </key>
    <key name="interactions-shortcut-raise-app" type="as">
      <default><![CDATA[['']]]></default>
    </key>
    <key name="interactions-shortcut-quit-app" type="as">
      <default><![CDATA[['']]]></default>
    </key>
    <key name="interactions-shortcut-open-preferences" type="as">
      <default><![CDATA[['']]]></default>
    </key>
    <key name="interactions-shortcut-next-app" type="as">
      <default><![CDATA[['']]]></default>
    </key>
    <key name="interactions-mouse-action-left"
         enum="org.gnome.shell.extensions.mediashell.input-actions">
      <default>'TOGGLE_POPUP'</default>
    </key>
    <key name="interactions-mouse-action-middle"
         enum="org.gnome.shell.extensions.mediashell.input-actions">
      <default>'OPEN_PREFERENCES'</default>
    </key>
    <key name="interactions-mouse-action-right"
         enum="org.gnome.shell.extensions.mediashell.input-actions">
      <default>'RAISE_APP'</default>
    </key>
    <key name="interactions-mouse-action-double"
         enum="org.gnome.shell.extensions.mediashell.input-actions">
      <default>'NONE'</default>
    </key>
    <key name="interactions-mouse-action-scroll-up"
         enum="org.gnome.shell.extensions.mediashell.input-actions">
      <default>'VOLUME_UP'</default>
    </key>
    <key name="interactions-mouse-action-scroll-down"
         enum="org.gnome.shell.extensions.mediashell.input-actions">
      <default>'VOLUME_DOWN'</default>
    </key>

    <!-- Others -->
    <key name="gnome-shell-hide-media-controls" type="b">
      <default>true</default>
    </key>
    <key name="album-art-cache-enabled" type="b">
      <default>true</default>
    </key>
    <key name="blocked-apps" type="as">
      <default>[]</default>
    </key>

  </schema>
</schemalist>
